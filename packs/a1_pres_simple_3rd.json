{
  "schema_version": 1,
  "skill": {
    "id": "a1_pres_simple_3rd",
    "cefr": "A1",
    "module": "a1_m2",
    "module_title_ru": "Настоящее простое",
    "title_ru": "Present Simple: he / she + V-s",
    "pattern": "he/she/it + глагол + -s/-es",
    "theory_ru": "С подлежащими he/she/it к глаголу в настоящем простом времени добавляется окончание **-s** (или **-es** после -s/-sh/-ch/-x/-o, и -y → -ies): **He works**, **She watches**, **He goes**. Это окончание легко забыть — самая частая ошибка русскоязычных в Present Simple.",
    "common_errors": [
      {
        "tag": "s_ending_missing",
        "ru": "Пропуск -s: ~He work~ → He **works**."
      },
      {
        "tag": "es_ending",
        "ru": "Забыто -es: ~He go~ → He **goes**."
      },
      {
        "tag": "y_to_ies",
        "ru": "study → studies, а не ~studys~."
      }
    ],
    "probe_item_ids": [
      "s_1365269",
      "s_10068609",
      "s_10068609"
    ],
    "youglish_query": "he works in an office"
  },
