# Copy to proxy/.env and fill in your own keys (never commit .env — it's gitignored).
GROQ_API_KEY=
OPENROUTER_API_KEY=
GIGACHAT_AUTH_KEY=
YANDEX_API_KEY=
PROXY_PORT=8787
# Safe default: only this computer can reach the proxy.
PROXY_HOST=127.0.0.1
# Add a deployed app origin only when needed, for example https://user.github.io.
PROXY_ALLOWED_ORIGINS=
